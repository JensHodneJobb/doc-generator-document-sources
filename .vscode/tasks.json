{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "docCategory",
      "type": "promptString",
      "description": "Category (for example: VARIANT_A)",
      "default": "VARIANT_A"
    }
  ],
  "tasks": [
    {
      "label": "DocGen SA40-0001: List Categories",
      "type": "shell",
      "command": "C:/ProgramData/anaconda3/python.exe",
      "args": [
        "C:/source/github/doc-generator/buildModularDocument.py",
        "${workspaceFolder}/SA40-0001",
        "--list"
      ],
      "options": {
        "cwd": "${workspaceFolder}/SA40-0001"
      },
      "problemMatcher": []
    },
    {
      "label": "DocGen SA40-0001: Build One Variant (PDF)",
      "type": "shell",
      "command": "C:/ProgramData/anaconda3/python.exe",
      "args": [
        "C:/source/github/doc-generator/buildModularDocument.py",
        "${workspaceFolder}/SA40-0001",
        "${input:docCategory}"
      ],
      "options": {
        "cwd": "${workspaceFolder}/SA40-0001"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "DocGen SA40-0001: Build All Variants",
      "type": "shell",
      "command": "C:/ProgramData/anaconda3/python.exe",
      "args": [
        "C:/source/github/doc-generator/buildModularDocument.py",
        "${workspaceFolder}/SA40-0001",
        "--all"
      ],
      "options": {
        "cwd": "${workspaceFolder}/SA40-0001"
      },
      "problemMatcher": []
    },
    {
      "label": "DocGen SA40-0001: Markdown Only",
      "type": "shell",
      "command": "C:/ProgramData/anaconda3/python.exe",
      "args": [
        "C:/source/github/doc-generator/buildModularDocument.py",
        "${workspaceFolder}/SA40-0001",
        "${input:docCategory}",
        "--md"
      ],
      "options": {
        "cwd": "${workspaceFolder}/SA40-0001"
      },
      "problemMatcher": []
    },
    {
      "label": "DocGen SA40-0001: Markdown + DOCX (No PDF)",
      "type": "shell",
      "command": "C:/ProgramData/anaconda3/python.exe",
      "args": [
        "C:/source/github/doc-generator/buildModularDocument.py",
        "${workspaceFolder}/SA40-0001",
        "${input:docCategory}",
        "--md",
        "--docx"
      ],
      "options": {
        "cwd": "${workspaceFolder}/SA40-0001"
      },
      "problemMatcher": []
    }
  ]
}
