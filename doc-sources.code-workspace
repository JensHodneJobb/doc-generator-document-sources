{
	"folders": [
		{
			"name": "Document Sources",
			"path": "."
		}
	],
	"settings": {
		"files.exclude": {
			"**/output": true
		},
		"markdown.extension.toc.levels": "1..3",
		"editor.wordWrap": "on",
		"files.eol": "\n"
	},
	"extensions": {
		"recommendations": [
			"yzhang.markdown-all-in-one",
			"davidanson.vscode-markdownlint",
			"redhat.vscode-yaml"
		]
	}
}
